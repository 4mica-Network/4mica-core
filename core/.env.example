# Required
DATABASE_URL=<database_url>
ETHEREUM_CHAIN_ID=<ethereum_chain_id>
ETHEREUM_HTTP_RPC_URL=<ethereum_http_rpc_url>
ETHEREUM_WS_RPC_URL=<ethereum_ws_rpc_url>
ETHEREUM_CONTRACT_ADDRESS=<ethereum_contract_address>
ETHEREUM_PRIVATE_KEY=<ethereum_private_key>
BLS_PRIVATE_KEY=<bls_private_key>
AUTH_JWT_SECRET=<auth_jwt_secret>

# Guarantee handling
# Preferred version advertised by /core/public-params.
GUARANTEE_REQUEST_VERSION=<guarantee_request_version>
# Optional explicit allowlist. If unset:
# - version 1 accepts only 1
# - version 2 accepts 1 and 2
GUARANTEE_ACCEPTED_REQUEST_VERSIONS=<guarantee_accepted_request_versions>
# Required whenever V2 guarantees are accepted.
TRUSTED_VALIDATION_REGISTRIES=<trusted_validation_registries>
VALIDATION_HASH_CANONICALIZATION_VERSION=4MICA_VALIDATION_REQUEST_V1

# Common optional overrides
SERVER_HOST=<server_host>
SERVER_PORT=<server_port>
LOG_LEVEL=<log_level>
EIP712_NAME=<eip712_name>
EIP712_VERSION=<eip712_version>
CONFIRMATION_MODE=finalized
FINALIZED_HEAD_DEPTH=<finalized_head_depth>
AUTH_JWT_ISSUER=<auth_jwt_issuer>
AUTH_JWT_AUDIENCE=<auth_jwt_audience>
