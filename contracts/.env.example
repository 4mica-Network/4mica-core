# ---------------------------------------------------------------------------
# Network / deployer
# ---------------------------------------------------------------------------

# EOA private key used by `forge script --broadcast`.
DEPLOYER_PRIVATE_KEY=<DEPLOYER_PRIVATE_KEY>

# Target RPC endpoint used by `forge script --rpc-url $DEPLOY_RPC_URL`.
DEPLOY_RPC_URL=<DEPLOY_RPC_URL>

# Optional AccessManager initial admin (defaults to deployer).
ACCESS_MANAGER_ADMIN=<ACCESS_MANAGER_ADMIN>

# Deterministic deployment salt seed for CREATE2 (same value => same addresses).
CREATE2_SALT=<CREATE2_SALT>

# ---------------------------------------------------------------------------
# Core4Mica deployment inputs
# ---------------------------------------------------------------------------

# v1 guarantee BLS public key in Core4Mica constructor (4 x bytes32 limbs).
VK_X0=<VK_X0>
VK_X1=<VK_X1>
VK_Y0=<VK_Y0>
VK_Y1=<VK_Y1>

# Stablecoin assets configured in the Core4Mica constructor.
# Example:
# STABLECOINS_COUNT=2
# STABLECOIN_0=0x...
# STABLECOIN_1=0x...
STABLECOINS_COUNT=<STABLECOINS_COUNT>
STABLECOIN_0=<STABLECOIN_0>
STABLECOIN_1=<STABLECOIN_1>

# ---------------------------------------------------------------------------
# Full-stack deploy (Core4MicaFullStack.s.sol)
# ---------------------------------------------------------------------------

# Trusted ERC-8004 ValidationRegistry allowlist for ValidationRegistryGuaranteeDecoder.
# Use either single:
TRUSTED_VALIDATION_REGISTRY=<TRUSTED_VALIDATION_REGISTRY>
# or multi-entry:
TRUSTED_VALIDATION_REGISTRIES_COUNT=<TRUSTED_VALIDATION_REGISTRIES_COUNT>
TRUSTED_VALIDATION_REGISTRY_0=<TRUSTED_VALIDATION_REGISTRY_0>
TRUSTED_VALIDATION_REGISTRY_1=<TRUSTED_VALIDATION_REGISTRY_1>

# ---------------------------------------------------------------------------
# Post-deploy configuration scripts
# ---------------------------------------------------------------------------

# For ConfigureGuaranteeVersion.s.sol:
CORE4MICA_ADDRESS=<CORE4MICA_ADDRESS>
GUARANTEE_VERSION=<GUARANTEE_VERSION>
GUARANTEE_ENABLED=<GUARANTEE_ENABLED>
GUARANTEE_REUSE_EXISTING_KEY=<GUARANTEE_REUSE_EXISTING_KEY>
# Source version to copy key from when GUARANTEE_REUSE_EXISTING_KEY=true (default 1).
GUARANTEE_KEY_SOURCE_VERSION=<GUARANTEE_KEY_SOURCE_VERSION>
GUARANTEE_DOMAIN_SEPARATOR=<GUARANTEE_DOMAIN_SEPARATOR>
GUARANTEE_DECODER=<GUARANTEE_DECODER>

# For ConfigureGuaranteeRouter.s.sol:
GUARANTEE_ROUTER_ADDRESS=<GUARANTEE_ROUTER_ADDRESS>
GUARANTEE_MODULE_ADDRESS=<GUARANTEE_MODULE_ADDRESS>
GUARANTEE_FREEZE_VERSION=<GUARANTEE_FREEZE_VERSION>

# ---------------------------------------------------------------------------
# Fork testing (Core4MicaAaveFork.t.sol)
# ---------------------------------------------------------------------------

# Base Sepolia example values sourced from the official Aave address book:
# https://raw.githubusercontent.com/bgd-labs/aave-address-book/main/src/AaveV3BaseSepolia.sol
#
# Run with:
# forge test --match-contract Core4MicaAaveForkTest

AAVE_FORK_RPC_URL=https://sepolia.base.org
AAVE_FORK_PROVIDER=0xE4C23309117Aa30342BFaae6c95c6478e0A4Ad00

# Base Sepolia Aave V3 supported stablecoins used by the fork test.
AAVE_FORK_STABLECOIN_0=0xba50Cd2A20f6DA35D788639E581bca8d0B5d4D5f
AAVE_FORK_STABLECOIN_1=0x0a215D8ba66387DCA84B284D18c3B4ec3de6E54a

# Matching Aave v3 aTokens for the assets above.
AAVE_FORK_STABLECOIN_ATOKEN_0=0x10F1A9D11CDf50041f3f8cB7191CBE2f31750ACC
AAVE_FORK_STABLECOIN_ATOKEN_1=0xcE3CAae5Ed17A7AafCEEbc897DE843fA6CC0c018
